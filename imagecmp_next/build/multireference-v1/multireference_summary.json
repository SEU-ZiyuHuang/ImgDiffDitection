{
  "schema_version": "multireference-pairing-v1",
  "scope": {
    "execution": "local-only",
    "source_images_copied": false,
    "source_images_exported": false
  },
  "naming_rules": {
    "live": "对比截图.jpg",
    "primary_reference": "标准源图.jpg",
    "additional_reference_pattern": "^新增标准源图(\\d+)\\.jpg$",
    "roi": "标准源图坐标.txt",
    "case_directory_depth": "direct child only"
  },
  "illumination_style": {
    "method": "luma median terciles over all readable live and reference images",
    "dark_medium_threshold": 102.0,
    "medium_bright_threshold": 116.5,
    "warning": "style bands are not verified day/night labels because no EXIF timestamps were found"
  },
  "geometry_policy": {
    "feature_match_count_min": 12,
    "inlier_count_min": 8,
    "inlier_rate_min": 0.4,
    "reprojection_error_pixels_max": 3.0,
    "spatial_coverage_min": 0.02,
    "projected_area_ratio_range": [
      0.2,
      5.0
    ],
    "valid_overlap_ratio_min": 0.6,
    "ecc_role": "masked raw and CLAHE ECC are observations only, not geometry gates",
    "ecc_max_side": 640,
    "ecc_iterations": 30
  },
  "counts": {
    "case_directories": 385,
    "primary_references": 385,
    "additional_references": 148,
    "multi_reference_cases": 105,
    "readable_live_images": 383,
    "readable_reference_images": 533,
    "unreadable_images": 2,
    "pair_records": 533,
    "geometry_usable_pairs": 443,
    "geometry_degraded_pairs": 72,
    "geometry_unavailable_pairs": 18,
    "selected_additional_reference_cases": 90,
    "cases_with_multiple_usable_references": 86
  }
}
