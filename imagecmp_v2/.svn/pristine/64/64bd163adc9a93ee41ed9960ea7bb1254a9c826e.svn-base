#include <algorithm>
#include <chrono>
#include <cmath>
#include <fstream>
#include <iostream>
#include <sstream>
#include <stdexcept>
#include <string>
#include <utility>
#include <vector>

#include <opencv2/opencv.hpp>
#include <onnxruntime_cxx_api.h>

class DeepDifferenceDetector {
public:
	DeepDifferenceDetector(const std::string &onnx_model_path = "resnet18.onnx");
	std::pair<cv::Mat, cv::Mat> preprocess_image(const cv::Mat &img, const cv::Size &target_size =
			cv::Size(224, 224));
	cv::Mat extract_features(const cv::Mat &pil_image);
	cv::Mat compute_dense_difference(const cv::Mat &feat_map1, const cv::Mat &feat_map2,
			const cv::Size &original_img_shape);
	std::vector<cv::Rect> detect_differences(const cv::Mat &srcimg1, const cv::Mat &srcimg2,
			float difference_threshold = 0.5f, float roi_diff_threshold = 0.2f,
			int min_contour_area = 1000, const cv::Size &target_img_size = cv::Size(224, 224));

	std::vector<cv::Rect> readYoloFormatToRects(const std::string &filePath, int imageWidth,
			int imageHeight);
	static cv::Rect templateMatching(const cv::Mat& largeImg,
		const cv::Mat& smallImg,
		double& maxVal,
		int method = cv::TM_CCOEFF_NORMED);

	float computer_sim(const cv::Mat &srcimg1, const cv::Mat &srcimg2,
			const cv::Size &target_img_size = cv::Size(224, 224));

private:
	Ort::Env env = Ort::Env(ORT_LOGGING_LEVEL_ERROR, "DEEPDIFF");
	Ort::SessionOptions session_options = Ort::SessionOptions();
	std::unique_ptr<Ort::Session> ort_session;

	std::vector<std::string> input_names;
	std::vector<std::string> output_names;
	std::string device;

	const std::vector<float> mean = { 0.485f, 0.456f, 0.406f };
	const std::vector<float> std_dev = { 0.229f, 0.224f, 0.225f };

};

std::vector<cv::Rect> DeepDifferenceDetector::readYoloFormatToRects(const std::string &filePath,
		int imageWidth, int imageHeight) {
	std::vector<cv::Rect> rects;
	std::ifstream file(filePath);

	if (!file.is_open()) {
		throw std::runtime_error("无法打开文件: " + filePath);
	}

	std::string line;
	while (std::getline(file, line)) {
		std::istringstream iss(line);
		int classId;
		float x_center, y_center, width, height;

		if (!(iss >> classId >> x_center >> y_center >> width >> height)) {
			continue;
		}

		int abs_width = static_cast<int>(width * imageWidth);
		int abs_height = static_cast<int>(height * imageHeight);
		int abs_x = static_cast<int>((x_center * imageWidth) - (abs_width / 2));
		int abs_y = static_cast<int>((y_center * imageHeight) - (abs_height / 2));

		abs_x = std::max(0, abs_x);
		abs_y = std::max(0, abs_y);
		abs_width = std::min(abs_width, imageWidth - abs_x);
		abs_height = std::min(abs_height, imageHeight - abs_y);

		rects.emplace_back(abs_x, abs_y, abs_width, abs_height);
	}

	return rects;

}

cv::Rect DeepDifferenceDetector::templateMatching(const cv::Mat &largeImg, 
	const cv::Mat &smallImg,
	double &maxVal,
		int method) {
	if (largeImg.empty() || smallImg.empty()) {
		throw std::invalid_argument("输入图像不能为空");
	}
	if (smallImg.rows > largeImg.rows || smallImg.cols > largeImg.cols) {
		throw std::invalid_argument("模板图像不能大于搜索图像");
	}

	cv::Mat result;
	int result_cols = largeImg.cols - smallImg.cols + 1;
	int result_rows = largeImg.rows - smallImg.rows + 1;
	result.create(result_rows, result_cols, CV_32FC1);

	cv::matchTemplate(largeImg, smallImg, result, method);

	double minVal;
	cv::Point minLoc, maxLoc;
	cv::minMaxLoc(result, &minVal, &maxVal, &minLoc, &maxLoc);

	cv::Point matchLoc;
	if (method == cv::TM_SQDIFF || method == cv::TM_SQDIFF_NORMED) {
		matchLoc = minLoc;
	} else {
		matchLoc = maxLoc;
	}

	return cv::Rect(matchLoc.x, matchLoc.y, smallImg.cols, smallImg.rows);
}

DeepDifferenceDetector::DeepDifferenceDetector(const std::string &onnx_model_path) {
	this->device = "cpu";

	std::cout << "初始化 DeepDifferenceDetector，使用设备: " << this->device << std::endl;

#ifdef  _WIN32
	std::wstring wide_model_path(onnx_model_path.begin(), onnx_model_path.end());
	this->ort_session = std::make_unique<Ort::Session>(env, wide_model_path.c_str(), session_options);
#else
	this->ort_session = std::make_unique < Ort::Session
			> (env, onnx_model_path.c_str(), session_options);
#endif

	Ort::AllocatorWithDefaultOptions allocator;

	Ort::AllocatedStringPtr input_name = ort_session->GetInputNameAllocated(0, allocator);
	this->input_names.push_back((char*)input_name.get());

	size_t num_outputs = this->ort_session->GetOutputCount();
	for (size_t i = 0; i < num_outputs; ++i) {
		Ort::AllocatedStringPtr output_name = this->ort_session->GetOutputNameAllocated(i, allocator);
		this->output_names.push_back((char*)output_name.get());
	}
}

std::pair<cv::Mat, cv::Mat> DeepDifferenceDetector::preprocess_image(const cv::Mat &img,
		const cv::Size &target_size) {
	if (img.empty()) {
		throw std::runtime_error("无法读取图像文件");
	}

	cv::Mat original_color_img = img.clone();

	cv::Mat img_3_channel;
	cv::cvtColor(img, img_3_channel, cv::COLOR_BGR2RGB);

	cv::Mat resized_rgb;
	cv::resize(img_3_channel, resized_rgb, target_size, 0, 0, cv::INTER_AREA);

	cv::Mat cv_img;
	cv::resize(original_color_img, cv_img, target_size);

	return {resized_rgb, cv_img};
}

cv::Mat normalizeMat(const cv::Mat &input) {
	cv::Mat norm;

	cv::Mat floatInput;
	if (input.depth() != CV_32F) {
		input.convertTo(floatInput, CV_32F);
	} else {
		floatInput = input.clone();
	}

	cv::multiply(floatInput, floatInput, norm);
	cv::reduce(norm, norm, 1, cv::REDUCE_SUM);
	cv::sqrt(norm, norm);

	cv::Mat mask = (norm == 0);
	norm.setTo(1.0, mask);

	cv::Mat result(floatInput.size(), CV_32F);
	for (int i = 0; i < floatInput.rows; ++i) {
		float *pInput = floatInput.ptr<float>(i);
		float *pResult = result.ptr<float>(i);
		float n = norm.at<float>(i, 0);

		for (int j = 0; j < floatInput.cols; ++j) {
			pResult[j] = pInput[j] / n;
		}
	}

	return result;
}

float cosineSimilarity(const cv::Mat &mat1, const cv::Mat &mat2) {
	if (mat1.cols != mat2.cols) {
		throw std::invalid_argument("Matrices must have the same number of columns");
	}

	float dot_product = mat1.dot(mat2);

	return dot_product;
}

float computeGlobalSimilarity(const cv::Mat &feat_map1_global, const cv::Mat &feat_map2_global) {
	cv::Mat flat1 = feat_map1_global.reshape(1,
			feat_map1_global.rows * feat_map1_global.cols * feat_map1_global.channels());
	cv::Mat flat2 = feat_map2_global.reshape(1,
			feat_map2_global.rows * feat_map2_global.cols * feat_map2_global.channels());

	flat1 = flat1.t();
	flat2 = flat2.t();

	cv::Mat feat_vec1_global = normalizeMat(flat1);
	cv::Mat feat_vec2_global = normalizeMat(flat2);

	float global_sim = cosineSimilarity(feat_vec1_global, feat_vec2_global);

	return global_sim;
}

cv::Mat DeepDifferenceDetector::extract_features(const cv::Mat &pil_image) {
	cv::Mat float_img;
	pil_image.convertTo(float_img, CV_32FC3, 1.0 / 255.0);

	std::vector<cv::Mat> channels;
	cv::split(float_img, channels);
	for (int c = 0; c < 3; ++c) {
		channels[c] = (channels[c] - mean[c]) / std_dev[c];
	}

	std::vector<float> input_tensor_values;
	input_tensor_values.reserve(1 * 3 * pil_image.rows * pil_image.cols);

	for (int c = 0; c < 3; ++c) {
		for (int h = 0; h < pil_image.rows; ++h) {
			for (int w = 0; w < pil_image.cols; ++w) {
				input_tensor_values.push_back(channels[c].at<float>(h, w));
			}
		}
	}

	std::vector<int64_t> input_shape = { 1, 3, pil_image.rows, pil_image.cols };
	Ort::MemoryInfo memory_info = Ort::MemoryInfo::CreateCpu(OrtArenaAllocator, OrtMemTypeDefault);
	Ort::Value input_tensor = Ort::Value::CreateTensor<float>(memory_info,
			input_tensor_values.data(), input_tensor_values.size(), input_shape.data(),
			input_shape.size());

	const char *_input_names[10];
	const char* _output_names[10];
	{
		for (int i = 0; i < input_names.size(); i++)
			_input_names[i] = input_names[i].c_str();
	}
	{
		for (int i = 0; i < output_names.size(); i++)
			_output_names[i] = output_names[i].c_str();
	}
	std::vector<Ort::Value> ort_outputs = ort_session->Run(Ort::RunOptions { nullptr },
		_input_names, &input_tensor, 1, _output_names, output_names.size());

	float *output_data = ort_outputs[0].GetTensorMutableData<float>();
	auto output_shape = ort_outputs[0].GetTensorTypeAndShapeInfo().GetShape();

	int batch_size = output_shape[0];
	int channels_out = output_shape[1];
	int height_out = output_shape[2];
	int width_out = output_shape[3];

	size_t total_elements = batch_size * channels_out * height_out * width_out;
	(void)total_elements;

	cv::Mat feat_map(width_out * height_out, channels_out, CV_32F);

	for (int c = 0; c < channels_out; ++c) {
		for (int h = 0; h < height_out; ++h) {
			for (int w = 0; w < width_out; ++w) {
				int src_idx = c * height_out * width_out + h * width_out + w;
				int dst_idx = h * width_out + w;
				feat_map.at<float>(dst_idx, c) = output_data[src_idx];
			}
		}
	}
	return feat_map;
}

cv::Mat DeepDifferenceDetector::compute_dense_difference(const cv::Mat &feat_map1,
		const cv::Mat &feat_map2, const cv::Size &original_img_shape) {
	cv::Mat feat1 = feat_map1;
	cv::Mat feat2 = feat_map2;

	if (feat1.size() != feat2.size()) {
		cv::resize(feat1, feat1, feat2.size(), 0, 0, cv::INTER_LINEAR);
	}

	cv::Mat feat1_norm = cv::Mat::zeros(feat1.size(), CV_32F);
	cv::Mat feat2_norm = cv::Mat::zeros(feat2.size(), CV_32F);

	for (int i = 0; i < feat1.rows; ++i) {
		cv::Mat row1 = feat1.row(i);
		cv::Mat row2 = feat2.row(i);

		float norm1 = cv::norm(row1, cv::NORM_L2);
		float norm2 = cv::norm(row2, cv::NORM_L2);

		cv::Mat norm_row1, norm_row2;
		if (norm1 > 1e-8) {
			norm_row1 = row1 / norm1;
		} else {
			norm_row1 = cv::Mat::zeros(row1.size(), CV_32F);
		}

		if (norm2 > 1e-8) {
			norm_row2 = row2 / norm2;
		} else {
			norm_row2 = cv::Mat::zeros(row2.size(), CV_32F);
		}

		norm_row1.copyTo(feat1_norm.row(i));
		norm_row2.copyTo(feat2_norm.row(i));
	}

	cv::Mat diff_map;
	cv::absdiff(feat1_norm, feat2_norm, diff_map);

	cv::Mat mean_diff = cv::Mat::zeros(diff_map.rows, 1, CV_32F);
	for (int i = 0; i < diff_map.rows; ++i) {
		cv::Scalar row_mean = cv::mean(diff_map.row(i));
		mean_diff.at<float>(i, 0) = row_mean[0];
	}

	int feat_h = static_cast<int>(std::sqrt(feat_map1.rows));
	cv::Mat spatial_diff = mean_diff.reshape(1, feat_h);

	double min_val, max_val;
	cv::minMaxLoc(spatial_diff, &min_val, &max_val);

	cv::Mat diff_map_normalized = (spatial_diff - min_val) / (max_val - min_val + 1e-8);

	cv::Mat upsampled_diff;
	cv::resize(diff_map_normalized, upsampled_diff, original_img_shape, 0, 0, cv::INTER_LINEAR);

	return upsampled_diff;
}

float DeepDifferenceDetector::computer_sim(const cv::Mat &srcimg1, const cv::Mat &srcimg2,
		const cv::Size &target_img_size) {
	std::pair<cv::Mat, cv::Mat> img1pi = this->preprocess_image(srcimg1, target_img_size);
	cv::Mat img1_pil = img1pi.first;

	std::pair<cv::Mat, cv::Mat> img2pi = this->preprocess_image(srcimg2, target_img_size);
	cv::Mat img2_pil = img2pi.first;

	cv::Mat feat_map1 = this->extract_features(img1_pil);
	cv::Mat feat_map2 = this->extract_features(img2_pil);

	float simplus = computeGlobalSimilarity(feat_map1, feat_map2);
	std::cout << "Global similarity: " << simplus << std::endl;

	return simplus;
}

std::vector<cv::Rect> DeepDifferenceDetector::detect_differences(const cv::Mat &srcimg1,
		const cv::Mat &srcimg2, float difference_threshold, float roi_diff_threshold,
		int min_contour_area, const cv::Size &target_img_size) {

	int srcw = srcimg1.cols, srch = srcimg1.rows;
	auto start_total = std::chrono::high_resolution_clock::now();

	auto start_preprocess = std::chrono::high_resolution_clock::now();
	auto img1pre = this->preprocess_image(srcimg1, target_img_size);
	auto img2pre = this->preprocess_image(srcimg2, target_img_size);

	cv::Mat img1_pil = img1pre.first;
	cv::Mat img1_cv = img1pre.second;

	cv::Mat img2_pil = img2pre.first;
	cv::Mat img2_cv = img2pre.second;

	auto time_preprocess = std::chrono::high_resolution_clock::now() - start_preprocess;

	auto start_feature = std::chrono::high_resolution_clock::now();
	cv::Mat feat_map1 = this->extract_features(img1_pil);
	cv::Mat feat_map2 = this->extract_features(img2_pil);
	auto time_feature = std::chrono::high_resolution_clock::now() - start_feature;

	auto start_diff = std::chrono::high_resolution_clock::now();
	cv::Size original_img_shape(img1_cv.cols, img1_cv.rows);
	cv::Mat diff_map = this->compute_dense_difference(feat_map1, feat_map2, original_img_shape);
	auto time_diff = std::chrono::high_resolution_clock::now() - start_diff;

	auto start_contour = std::chrono::high_resolution_clock::now();

	cv::Mat diff_map_smoothed;
	cv::GaussianBlur(diff_map, diff_map_smoothed, cv::Size(5, 5), 3);

	cv::Mat binary = diff_map_smoothed > difference_threshold;

	cv::Mat kernel = cv::getStructuringElement(cv::MORPH_ELLIPSE, cv::Size(7, 7));
	cv::morphologyEx(binary, binary, cv::MORPH_CLOSE, kernel);
	cv::morphologyEx(binary, binary, cv::MORPH_OPEN, kernel);

	std::vector<std::vector<cv::Point>> contours;
	cv::findContours(binary, contours, cv::RETR_EXTERNAL, cv::CHAIN_APPROX_SIMPLE);

	cv::Mat output_img;
	cv::hconcat(img1_cv, img2_cv, output_img);
	int count = 0;

	std::vector<cv::Rect> tarrects;
	for (const auto &c : contours) {
		double area = cv::contourArea(c);
		std::cout << "area:" << area << std::endl;
		if (area > min_contour_area) {
			cv::Rect rect = cv::boundingRect(c);
			cv::Mat roi = diff_map(rect);
			float roi_diff = cv::mean(roi)[0];

			if (roi_diff > roi_diff_threshold) {
				int tarcx = int(float(rect.x) / target_img_size.width * srcw);
				int tarcy = int(float(rect.y) / target_img_size.height * srch);
				int tarcw = int(float(rect.width) / target_img_size.width * srcw);
				int tarch = int(float(rect.height) / target_img_size.height * srch);
				std::cout << tarcx << std::endl;
				tarrects.push_back(cv::Rect(tarcx, tarcy, tarcw, tarch));
				count++;
			}
		}
	}

	auto time_contour = std::chrono::high_resolution_clock::now() - start_contour;
	auto total_time = std::chrono::high_resolution_clock::now() - start_total;

	std::cout << "\n===== 性能统计 =====" << std::endl;
	std::cout << "图像预处理耗时: " << std::chrono::duration_cast < std::chrono::milliseconds
			> (time_preprocess).count() << "毫秒" << std::endl;
	std::cout << "特征提取耗时: " << std::chrono::duration_cast < std::chrono::milliseconds
			> (time_feature).count() << "毫秒" << std::endl;
	std::cout << "差异计算耗时: " << std::chrono::duration_cast < std::chrono::milliseconds
			> (time_diff).count() << "毫秒" << std::endl;
	std::cout << "轮廓检测耗时: " << std::chrono::duration_cast < std::chrono::milliseconds
			> (time_contour).count() << "毫秒" << std::endl;
	std::cout << "总耗时: " << std::chrono::duration_cast < std::chrono::milliseconds
			> (total_time).count() << "毫秒" << std::endl;
	std::cout << "检测到 " << count << " 个显著差异区域" << std::endl;

	return tarrects;
}

std::vector<cv::Mat> splitInto3x3(const cv::Mat &src) {
	std::vector<cv::Mat> tiles;

	CV_Assert(src.rows % 3 == 0 && src.cols % 3 == 0);

	const int tile_width = src.cols / 3;
	const int tile_height = src.rows / 3;

	for (int i = 0; i < 3; ++i) {
		for (int j = 0; j < 3; ++j) {
			cv::Rect roi(j * tile_width, i * tile_height, tile_width, tile_height);
			tiles.push_back(src(roi).clone());
		}
	}

	return tiles;
}

#endif

