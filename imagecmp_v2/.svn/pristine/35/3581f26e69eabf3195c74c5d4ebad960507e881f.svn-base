if(NOT DEFINED CMAKE_INSTALL_PREFIX)
    set(CMAKE_INSTALL_PREFIX "${CMAKE_BINARY_DIR}/install" CACHE PATH "Installation Directory")
endif()
message(STATUS "CMAKE_INSTALL_PREFIX = ${CMAKE_INSTALL_PREFIX}")

#find_package(PythonInterp REQUIRED)
cmake_minimum_required(VERSION 3.5.1)

set(CMAKE_CONFIGURATION_TYPES "Release")
cmake_policy(SET CMP0077 NEW)

if(WIN32)
	set(CMAKE_RUNTIME_OUTPUT_DIRECTORY_DEBUG ${CMAKE_INSTALL_PREFIX}/debug)
	set(CMAKE_RUNTIME_OUTPUT_DIRECTORY_RELEASE ${CMAKE_INSTALL_PREFIX}/release)
endif()

project(lximagecmp)

set(CMAKE_CXX_STANDARD 14)

#
if(WIN32)
	add_definitions(-D_CRT_SECURE_NO_WARNINGS)
	#https://segmentfault.com/q/1010000042696634 您不需要任何导出宏到类或函数！ 使用此方法时不能使用 /GL（ 全程序优化）！
	#set(CMAKE_WINDOWS_EXPORT_ALL_SYMBOLS ON)
	# windows release模式下生成pdb文件
	set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} /wd4996 /Zi /utf-8")
	set(CMAKE_SHARED_LINKER_FLAGS_RELEASE "${CMAKE_SHARED_LINKER_FLAGS_RELEASE} /DEBUG /OPT:REF /OPT:ICF")
	set(CMAKE_EXE_LINKER_FLAGS_RELEASE "${CMAKE_EXE_LINKER_FLAGS_RELEASE} /DEBUG /OPT:REF /OPT:ICF")
	# 关闭优化
	string(REPLACE "/O2" "/Od" CMAKE_CXX_FLAGS_RELEASE "${CMAKE_CXX_FLAGS_RELEASE}")
	string(REPLACE "/O2" "/Od" CMAKE_C_FLAGS_RELEASE "${CMAKE_C_FLAGS_RELEASE}")
else()
	set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -fvisibility=hidden")	
endif()

if(WIN32)

	if(EXISTS "D:/opencv4.7.0/opencv/build")
		set(OpenCV_Dir D:/opencv4.7.0/opencv/build)
	endif()

	if(EXISTS "E:/lxwork/svn_project/PRE/chenjian/test_opencv_imagecmp/deps/onnxruntime-win-x64-1.14.1")
		set(onnxruntime_dir "E:/lxwork/svn_project/PRE/chenjian/test_opencv_imagecmp/deps/onnxruntime-win-x64-1.14.1")
	endif()

else()
	# Ascend / CANN
	set(ASCEND_HOME "/usr/local/Ascend/ascend-toolkit/latest" CACHE PATH "Ascend toolkit root")

	# OpenCV (your environment)
	set(OPENCV_ROOT "/opt/work/nfs95/imagecmp_v2/deps" CACHE PATH "OpenCV prefix")
	if(NOT OpenCV_DIR AND EXISTS "${OPENCV_ROOT}/lib/cmake/opencv4")
		set(OpenCV_DIR "${OPENCV_ROOT}/lib/cmake/opencv4" CACHE PATH "OpenCV config dir")
	endif()
endif()

find_package(OpenCV REQUIRED)
if (OpenCV_FOUND)
    message(STATUS "OpenCV library status:")
    message(STATUS "    version: ${OpenCV_VERSION}")
	message(STATUS "    libraries: ${OpenCV_LIBS}")
    message(STATUS "    include path: ${OpenCV_INCLUDE_DIRS}" \n)
else ()
    message(FATAL_ERROR "Could not locate OpenCV_Dir" \n)
endif()

include_directories(
    ${ASCEND_HOME}/acllib/include
	${OpenCV_INCLUDE_DIRS}
	${CMAKE_CURRENT_SOURCE_DIR}
)

link_directories(${ASCEND_HOME}/acllib/lib64)

add_library(${PROJECT_NAME} SHARED
	yidong_main.cpp
	ascend_infer.cpp
	deep_difference_detector.cpp
	ldc.cpp
	image_matcher.cpp
	imagecmp.cpp
	base64.c
	Laplacian.cpp
)


if(WIN32)
	# Windows 仍可沿用原 ONNXRuntime 版本（如需），当前 v2 已切昇腾，默认不配置 onnxruntime
	target_link_libraries(${PROJECT_NAME} ${OpenCV_LIBS})
else()
	
	target_link_libraries(${PROJECT_NAME}
		${OpenCV_LIBS}
		ascendcl
		acl_dvpp
		dl
		rt
		pthread
	)
	set_target_properties(${PROJECT_NAME} PROPERTIES
		LINK_FLAGS "-Wl,-rpath,$ORIGIN:$ORIGIN/libs:./libs:${OPENCV_ROOT}/lib,-disable-new-dtags"
	)
endif()

#测试程序
add_executable(test test.cpp)

target_link_libraries(test ${PROJECT_NAME} ${ASCEND_HOME}/acllib/lib64)

if(WIN32)
else()
	target_link_libraries(test pthread dl rt)
endif()

set_target_properties(test PROPERTIES LINK_FLAGS "-Wl,-rpath,$ORIGIN:$ORIGIN/libs:./libs:/data/lxapp/aitask/libs,-disable-new-dtags")
