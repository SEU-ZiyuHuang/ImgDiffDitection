cv::Mat resizeAndPad(const cv::Mat &input, int target_size);

extern "C" {
//liveImagePath: 实时图像地址
//tempImagePath: 样本图像地址
//yolo(x,y,w,h): yolo坐标点(对应样本图片)
//float threshold,
//outCropImagePath: 输出的切图地址(需要缩放成640)
//return -1; notfind, -2 error; 0 没有找到; 1 找到
int lxImageFind(const char *liveImagePath, const char *tempImagePath,
		float yolo_x, float yolo_y, float yolo_w, float yolo_h, float threshold,
		float *simres, Box *box, const char *outCropImagePath, int resize) {
	cv::Mat img1 = cv::imread(liveImagePath); //BGR
	cv::Mat img2 = cv::imread(tempImagePath); //BGR

	if (img1.empty() || img2.empty()) {
		printf("error: not open image\n");
		return -2;
	}

	if (img1.rows != img2.rows || img1.cols != img2.cols) {
		printf("image size not equ\n");
		return -3;
	}

	try {
		int img_width = img2.cols;
		int img_height = img2.rows;
		int x1, y1, box_width, box_height;
		yolo2rect(yolo_x, yolo_y, yolo_w, yolo_h, img_width, img_height, x1, y1,
				box_width, box_height);
		printf("yolo2rect: %d,%d,%d,%d\n", x1, y1, box_width, box_height);
		if (x1 < 0 || y1 < 0 || box_width <= 3 || box_height <= 3) {
			std::cerr << "坐标或尺寸无效！" << std::endl;
			return -4;
		}
		if (x1 + box_width > img_width || y1 + box_height > img_height) {
			std::cerr << "范围超过图像大小！" << std::endl;
			return -5;
		}

		// 截图: 复制一份新的
		cv::Mat img2Crop =
				img2(cv::Rect(x1, y1, box_width, box_height)).clone();
		if(img2Crop.empty())
		{
			std::cerr << "截图为空" << std::endl;
			return -6;
		}

		//需要寻找
		//查找最佳匹配物体
		int findType = -1;
		std::pair<cv::Rect, double> result = find_best_match(img1, img2Crop, findType);
		cv::Rect best_match = result.first;
		double match_score = result.second;

		if (best_match.empty())
			return -1;

		cv::Mat img1Crop = img1(best_match).clone();
		if(img1Crop.empty())
		{
			std::cerr << "best_match截图为空" << std::endl;
			return -6;
		}

		//还需要做异动对比
		{
			//计算结构相似性指数
			double score = calculate_hist_similarity(img1Crop, img2Crop);
			*simres = score;
			if (score > threshold) {
				return 0;
			}

			cv::Mat gray1, gray2;
			cv::cvtColor(img1Crop, gray1, cv::COLOR_BGR2GRAY);
			cv::cvtColor(img2Crop, gray2, cv::COLOR_BGR2GRAY);

			//# 对齐图片
			cv::Mat aligned_img = align_images(gray1, gray2, img2Crop);
			if (aligned_img.empty()) {
				printf("空对其\n");
				aligned_img = img2Crop;
			}

			cv::Mat crop_gray2;
			cv::cvtColor(aligned_img, crop_gray2, cv::COLOR_BGR2GRAY);
			printf("diff:(%d,%d) (%d,%d)\n", gray1.cols, gray1.rows,
					crop_gray2.cols, crop_gray2.rows);

			//# 计算差异并标记
			std::vector<cv::Rect> diffs = find_differences(gray1, crop_gray2);
			if (diffs.size()) {
				box->x = diffs[0].x + x1; //位置需要匹配到大图中,故而增加截图区域的xy
				box->y = diffs[0].y + y1;
				box->w = diffs[0].width;
				box->h = diffs[0].height;

				float rect_area = box->w * box->h;
				float box_area = box_width * box_height;
				if (rect_area / box_area > 0.8) {
					box->x = 0;
					box->y = 0;
					box->w = 0;
					box->h = 0;
					return 0;
				}

				if (outCropImagePath && strlen(outCropImagePath) > 0) {
					if (resize > 0) {
						cv::Mat out = resizeAndPad(img1Crop, resize);
						cv::imwrite(outCropImagePath, out);
					} else
						cv::imwrite(outCropImagePath, img1Crop);
				}

				return 1;
			}
		}
	} catch (const std::exception &e) {
		std::cerr << "发生异常: Exception in lxImageFind: " << e.what() << std::endl;
		return -4; // 返回错误代码
	}
	return 0;
}

}
