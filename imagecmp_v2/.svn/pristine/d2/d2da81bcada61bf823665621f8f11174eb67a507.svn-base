/*
 新异动算法
 算法部分
 输入参数  实时大图   标准样本大图   部件yolo坐标   切图文件输出地址
 输出 相似度 差异区域坐标  按照切图文件地址生成文件
 步骤：
 1. 使用部件坐标从标准样本大图，切分出标准部件小图。
 2. 使用标准部件小图从实时大图上匹配出对应结果，
 如分数小于50（可配置，最好输入参数传进来），认为未找到结果，直接返回异常（要定义好，这种异常我们要上报，要和之前图片没找到返回-1做区分）
 如分数大于50，认为找到结果，将结果切分出来为实时部件小图
 3. 将实时部件小图和标准部件小图做异地对比（对齐、比较、合并区域等）
 4. 将异动结果返回，并将实时部件小图缩放到640x640保存到切图文件地址（宽和高有一个大于640就缩放，都小于640不缩放直接放在画布中间）
 */
#include "imagecmp.h"

// 可视化最佳匹配结果
void visualize_result(const cv::Mat &large_img, const cv::Mat &template_img,
		const cv::Rect &best_match, double score, const std::string &method) {
	// 创建图像副本用于绘制
	cv::Mat result_img = large_img.clone();
	rectangle(result_img, best_match, cv::Scalar(0, 255, 0), 3);

	// 在框上方添加匹配分数和方法
	std::string score_text = "匹配分数: " + std::to_string(score).substr(0, 6)
			+ " (" + method + ")";
	cv::putText(result_img, score_text,
			cv::Point(best_match.x, best_match.y - 10),
			cv::FONT_HERSHEY_SIMPLEX, 0.7, cv::Scalar(0, 255, 0), 2);

	// 在左上角添加小图
	cv::Mat small_template;
	resize(template_img, small_template, cv::Size(), 0.5, 0.5);
	int small_h = small_template.rows;
	int small_w = small_template.cols;
	small_template.copyTo(result_img(cv::Rect(10, 10, small_w, small_h)));
	putText(result_img, "目标小图", cv::Point(10, 10 + small_h + 20),
			cv::FONT_HERSHEY_SIMPLEX, 0.6, cv::Scalar(0, 255, 255), 1);

	// 保存结果
	std::string save_path = "_best_match.jpg";
	imwrite(save_path, result_img);
	std::cout << "结果已保存至: " << save_path << std::endl;

	// 显示结果
	cv::namedWindow("最佳匹配物体", cv::WINDOW_NORMAL);
	cv::imshow("最佳匹配物体", result_img);
	cv::waitKey(0);
}

// 使用模板匹配查找最佳匹配物体
std::pair<cv::Rect, double> template_match(const cv::Mat &large_img,
		const cv::Mat &template_img) {
	// 转换为灰度图提高速度
	cv::Mat gray_large, gray_template;
	cv::cvtColor(large_img, gray_large, cv::COLOR_BGR2GRAY);
	cv::cvtColor(template_img, gray_template, cv::COLOR_BGR2GRAY);

	// 执行模板匹配
	cv::Mat result;
	cv::matchTemplate(gray_large, gray_template, result, cv::TM_CCOEFF_NORMED);

	// 找到最佳匹配位置和分数
	double min_val, max_val;
	cv::Point min_loc, max_loc;
	cv::minMaxLoc(result, &min_val, &max_val, &min_loc, &max_loc);

	// 获取模板尺寸
	int w = gray_template.cols;
	int h = gray_template.rows;
	int x = max_loc.x;
	int y = max_loc.y;

	return { {x, y, w, h}, max_val};
}

// 使用特征匹配查找最佳匹配物体
std::pair<cv::Rect, double> feature_match(const cv::Mat &large_img,
		const cv::Mat &template_img) {
	// 初始化ORB检测器
	cv::Ptr < cv::ORB > orb = cv::ORB::create(500);

	// 检测关键点和描述符
	std::vector<cv::KeyPoint> kp1, kp2;
	cv::Mat des1, des2;
	orb->detectAndCompute(template_img, cv::noArray(), kp1, des1);
	orb->detectAndCompute(large_img, cv::noArray(), kp2, des2);

	// 如果没有特征点，返回空
	if (des1.empty() || des2.empty()) {
		return { {0, 0, 0, 0}, -1.0};
	}

	// 使用BFMatcher进行匹配
	cv::BFMatcher bf(cv::NORM_HAMMING, true);
	std::vector<cv::DMatch> matches;
	bf.match(des1, des2, matches);

	// 如果没有足够匹配，返回空
	if (matches.size() < 4) {
		return { {0, 0, 0, 0}, -1.0};
	}

	// 获取模板和图像中的点
	std::vector<cv::Point2f> src_pts, dst_pts;
	for (const auto &match : matches) {
		src_pts.push_back(kp1[match.queryIdx].pt);
		dst_pts.push_back(kp2[match.trainIdx].pt);
	}

	// 使用RANSAC计算单应性矩阵
	cv::Mat M, mask;
	M = findHomography(src_pts, dst_pts, cv::RANSAC, 5.0, mask);

	// 如果找不到单应性矩阵，返回空
	if (M.empty()) {
		return { {0, 0, 0, 0}, -1.0};
	}

	// 计算匹配分数 (内点比例)
	double inlier_ratio = countNonZero(mask) / double(mask.rows);

	// 获取模板的四个角点
	int h = template_img.rows;
	int w = template_img.cols;
	//std::vector<cv::Point2f> pts = { {0, 0}, {0, h - 1}, {w - 1, h - 1}, {w - 1, 0} };
	std::vector<cv::Point2f> pts = { cv::Point2f(0.0f, 0.0f), cv::Point2f(0.0f,
			static_cast<float>(h - 1)), cv::Point2f(static_cast<float>(w - 1),
			static_cast<float>(h - 1)), cv::Point2f(static_cast<float>(w - 1),
			0.0f) };

	// 应用单应性矩阵变换
	std::vector<cv::Point2f> dst;
	perspectiveTransform(pts, dst, M);

	// 计算边界框
	float x_min = std::min( { dst[0].x, dst[1].x, dst[2].x, dst[3].x });
	float x_max = std::max( { dst[0].x, dst[1].x, dst[2].x, dst[3].x });
	float y_min = std::min( { dst[0].y, dst[1].y, dst[2].y, dst[3].y });
	float y_max = std::max( { dst[0].y, dst[1].y, dst[2].y, dst[3].y });
	int width = int(x_max - x_min);
	int height = int(y_max - y_min);

	return { {int(x_min), int(y_min), width, height}, inlier_ratio};
}

// 在大图中查找与目标小图最相似的物体（匹配度最高的一个）
std::pair<cv::Rect, double> find_best_match(cv::Mat &large_img,
		cv::Mat &template_img, int &findType) {

	// 方法1: 模板匹配 (快速且直接)
	std::pair<cv::Rect, double> best_template_match = template_match(large_img,
			template_img);

	// 方法2: 特征匹配 (更鲁棒)
	std::pair<cv::Rect, double> best_feature_match = feature_match(large_img,
			template_img);

	// 比较两种方法的匹配分数，选择最佳匹配
	std::pair<cv::Rect, double> best_match;
	double highest_score = -1.0;
	//std::string method;

	if (best_template_match.second > highest_score) {
		best_match = best_template_match;
		highest_score = best_template_match.second;
		//method = "模板匹配";

		findType = 0;
	}

	if (best_feature_match.second > highest_score) {
		best_match = best_feature_match;
		highest_score = best_feature_match.second;
		//method = "特征匹配";

		findType = 1;
	}

#if CONFIG_DEBUG_SHOW
    // 可视化结果
    if (highest_score > -1.0) {
        visualize_result(large_img, template_img, best_match.first, highest_score, method);
    }
    else {
        std::cout << "未找到匹配的物体" << std::endl;
    }
#endif
	return best_match;
}

