class DeepDifferenceDetector {
public:
	DeepDifferenceDetector(const std::string &onnx_model_path = "resnet18.onnx");
	std::pair<cv::Mat, cv::Mat> preprocess_image(const cv::Mat &img, const cv::Size &target_size =
			cv::Size(224, 224));
	cv::Mat extract_features(const cv::Mat &pil_image);
	cv::Mat compute_dense_difference(const cv::Mat &feat_map1, const cv::Mat &feat_map2,
			const cv::Size &original_img_shape);
	std::vector<cv::Rect> detect_differences(const cv::Mat &srcimg1, const cv::Mat &srcimg2,
			float difference_threshold = 0.5f, float roi_diff_threshold = 0.2f,
			int min_contour_area = 1000, const cv::Size &target_img_size = cv::Size(224, 224));

	std::vector<cv::Rect> readYoloFormatToRects(const std::string &filePath, int imageWidth,
			int imageHeight);
	static cv::Rect templateMatching(const cv::Mat& largeImg,
		const cv::Mat& smallImg,
		double& maxVal,
		int method = cv::TM_CCOEFF_NORMED);

	float computer_sim(const cv::Mat &srcimg1, const cv::Mat &srcimg2,
			const cv::Size &target_img_size = cv::Size(224, 224));

private:
