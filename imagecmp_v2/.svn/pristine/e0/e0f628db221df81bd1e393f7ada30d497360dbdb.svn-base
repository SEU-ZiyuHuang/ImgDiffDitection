std::vector<cv::Rect> DeepDifferenceDetector::readYoloFormatToRects(const std::string &filePath,
		int imageWidth, int imageHeight) {
	std::vector<cv::Rect> rects;
	std::ifstream file(filePath);

	if (!file.is_open()) {
		throw std::runtime_error("无法打开文件: " + filePath);
	}

	std::string line;
	while (std::getline(file, line)) {
		std::istringstream iss(line);
		int classId;
		float x_center, y_center, width, height;

		// 读取每行数据
		if (!(iss >> classId >> x_center >> y_center >> width >> height)) {
			continue; // 跳过格式错误的行
		}

		// 将YOLO格式(相对坐标)转换为绝对坐标
		int abs_width = static_cast<int>(width * imageWidth);
		int abs_height = static_cast<int>(height * imageHeight);
		int abs_x = static_cast<int>((x_center * imageWidth) - (abs_width / 2));
		int abs_y = static_cast<int>((y_center * imageHeight) - (abs_height / 2));

		// 确保坐标在图像范围内
		abs_x = std::max(0, abs_x);
		abs_y = std::max(0, abs_y);
		abs_width = std::min(abs_width, imageWidth - abs_x);
		abs_height = std::min(abs_height, imageHeight - abs_y);

		rects.emplace_back(abs_x, abs_y, abs_width, abs_height);
	}

	return rects;

}

cv::Rect DeepDifferenceDetector::templateMatching(const cv::Mat &largeImg, 
	const cv::Mat &smallImg,
	double &maxVal,
		int method) {
	// 检查输入图像是否有效
	if (largeImg.empty() || smallImg.empty()) {
		throw std::invalid_argument("输入图像不能为空");
	}
	if (smallImg.rows > largeImg.rows || smallImg.cols > largeImg.cols) {
		throw std::invalid_argument("模板图像不能大于搜索图像");
	}

	// 创建结果矩阵
	cv::Mat result;
	int result_cols = largeImg.cols - smallImg.cols + 1;
	int result_rows = largeImg.rows - smallImg.rows + 1;
	result.create(result_rows, result_cols, CV_32FC1);

	// 执行模板匹配
	cv::matchTemplate(largeImg, smallImg, result, method);

	// 找到最佳匹配位置
	double minVal;
	cv::Point minLoc, maxLoc;
	cv::minMaxLoc(result, &minVal, &maxVal, &minLoc, &maxLoc);

	// 根据匹配方法确定最佳匹配点
	cv::Point matchLoc;
	if (method == cv::TM_SQDIFF || method == cv::TM_SQDIFF_NORMED) {
		matchLoc = minLoc;
	} else {
		matchLoc = maxLoc;
	}

	// 返回匹配的矩形区域
	return cv::Rect(matchLoc.x, matchLoc.y, smallImg.cols, smallImg.rows);
}

DeepDifferenceDetector::DeepDifferenceDetector(const std::string &onnx_model_path) {
	this->device = "cpu"; // 简化版本，只使用CPU

	std::cout << "初始化 DeepDifferenceDetector，使用设备: " << this->device << std::endl;

	// 加载ONNX模型
#ifdef  _WIN32
    //windows下编译需要这样写
    std::wstring wide_model_path(onnx_model_path.begin(), onnx_model_path.end());
    this->ort_session = std::make_unique<Ort::Session>(env, wide_model_path.c_str(), session_options);
#else
	this->ort_session = std::make_unique < Ort::Session
			> (env, onnx_model_path.c_str(), session_options);
#endif //  _WIN32

	Ort::AllocatorWithDefaultOptions allocator;

	//this->input_names.push_back(this->ort_session->GetInputName(0, allocator));
	Ort::AllocatedStringPtr input_name = ort_session->GetInputNameAllocated(0, allocator);
	this->input_names.push_back((char*)input_name.get());

	// 获取所有输出名称
	size_t num_outputs = this->ort_session->GetOutputCount();
	for (size_t i = 0; i < num_outputs; ++i) {
		Ort::AllocatedStringPtr output_name = this->ort_session->GetOutputNameAllocated(i, allocator);
		this->output_names.push_back((char*)output_name.get());
	}
}

