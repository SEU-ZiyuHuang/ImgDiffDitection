#include "imagecmp.h"

double calculate_hist_similarity(cv::Mat &img1, cv::Mat &img2)
{
	//计算两张图片的直方图相似度
	//:return : 两张图片的直方图相似度

	//# 将图片转换为HSV格式

	cv::Mat hsv1, hsv2;
	cv::cvtColor(img1, hsv1, cv::COLOR_BGR2HSV);
	cv::cvtColor(img2, hsv2, cv::COLOR_BGR2HSV);

	/****
	 # 计算直方图
	 hist1 = cv2.calcHist([hsv1], [0, 1], None, [180, 256], [0, 180, 0, 256])
	 hist2 = cv2.calcHist([hsv2], [0, 1], None, [180, 256], [0, 180, 0, 256])

	 # 归一化直方图
	 cv2.normalize(hist1, hist1, 0, 1, cv2.NORM_MINMAX)
	 cv2.normalize(hist2, hist2, 0, 1, cv2.NORM_MINMAX)

	 # 计算直方图相似度
	 similarity = cv2.compareHist(hist1, hist2, cv2.HISTCMP_BHATTACHARYYA)

	 return 1 - similarity / 2
	 **/
	// 计算直方图
	int h_bins = 180;
	int s_bins = 256;
	int histSize[] = { h_bins, s_bins };
	float h_ranges[] = { 0, 180 };
	float s_ranges[] = { 0, 256 };
	const float *ranges[] = { h_ranges, s_ranges };
	int channels[] = { 0, 1 };

	cv::Mat hist1, hist2;
	cv::calcHist(&hsv1, 1, channels, cv::Mat(), hist1, 2, histSize, ranges);
	cv::calcHist(&hsv2, 1, channels, cv::Mat(), hist2, 2, histSize, ranges);

	// 归一化直方图
	cv::normalize(hist1, hist1, 0, 1, cv::NORM_MINMAX);
	cv::normalize(hist2, hist2, 0, 1, cv::NORM_MINMAX);

	// 计算直方图相似度
    // 比较直方图：使用 cv2.compareHist 比较两张图片的直方图。
    //cv2.HISTCMP_CORREL：相关性比较方法，值范围在 [-1, 1]，值越接近 1 表示越相似。
    //cv2.HISTCMP_CHISQR：卡方比较方法，值越小表示越相似。
    //cv2.HISTCMP_INTERSECT：交集比较方法，值越大表示越相似。
    //cv2.HISTCMP_BHATTACHARYYA：巴氏距离比较方法，值越小表示越相似。
    //cv2.HISTCMP_HELLINGER：与巴氏距离类似，值越小表示越相似
	double similarity = cv::compareHist(hist1, hist2, cv::HISTCMP_BHATTACHARYYA);

	// 创建SSIM评估对象
	//cv::Ptr<cv::quality::QualitySSIM> ssim = cv::quality::QualitySSIM::create();
	// 计算SSIM
	//cv::Scalar score = ssim->compute(hist1, hist2);
	// 输出SSIM值
    //std::cout << "SSIM Score: " << score[0] << std::endl;
	return 1 - similarity;
}

//对其图像
cv::Mat align_images(cv::Mat &base_gray, cv::Mat &target_gray,
	cv::Mat &target_img) {
	/***# 使用ORB检测特征点，使用默认参数
	 orb = cv2.ORB_create()
	 kp1, des1 = orb.detectAndCompute(base_gray, None)
	 kp2, des2 = orb.detectAndCompute(target_gray, None)

	 if des1 is None or des2 is None or len(des1) < 2 or len(des2) < 2:
	 return None
	 **/
	cv::Ptr<cv::ORB> orb = cv::ORB::create();
	std::vector<cv::KeyPoint> kp1, kp2;
	cv::Mat des1, des2;

	orb->detectAndCompute(base_gray, cv::Mat(), kp1, des1);
	orb->detectAndCompute(target_gray, cv::Mat(), kp2, des2);

	if (des1.empty() || des2.empty() || des1.rows < 2 || des2.rows < 2) {
		return cv::Mat();
	}

	/*****
	 # 使用基本的特征点匹配，适当调整距离比率阈值以平衡匹配质量和数量
	 bf = cv2.BFMatcher(cv2.NORM_HAMMING)
	 matches = bf.knnMatch(des1, des2, k=2)
	 good_matches = []
	 for m, n in matches:
	 if m.distance < 0.7 * n.distance:  # 调整距离比率阈值
	 good_matches.append(m)

	 if len(good_matches) < 4:
	 print(len(good_matches))
	 return None
	 ****/
	cv::BFMatcher bf(cv::NORM_HAMMING);
	std::vector<std::vector<cv::DMatch>> matches;
	bf.knnMatch(des1, des2, matches, 2);

	std::vector<cv::DMatch> good_matches;
	for (size_t i = 0; i < matches.size(); i++) {
		if (matches[i][0].distance < 0.7 * matches[i][1].distance) { // 调整距离比率阈值
			good_matches.push_back(matches[i][0]);
		}
	}

	if (good_matches.size() < 4) {
		std::cout << good_matches.size() << std::endl;
		return cv::Mat();
	}

	/**
	 # 提取匹配点
	 src_pts = np.float32([kp1[m.queryIdx].pt for m in good_matches]).reshape(-1,1,2)
	 dst_pts = np.float32([kp2[m.trainIdx].pt for m in good_matches]).reshape(-1,1,2)
	 **/
	std::vector<cv::Point2f> src_pts, dst_pts;
	for (const auto &match : good_matches) {
		src_pts.push_back(kp1[match.queryIdx].pt);
		dst_pts.push_back(kp2[match.trainIdx].pt);
	}

	/****
	 # 调整RANSAC参数以提高匹配成功率
	 H, mask = cv2.findHomography(dst_pts, src_pts, cv2.RANSAC, 3.0)  # 调整RANSAC精度阈值
	 if H is None:
	 return None
	 ****/
	cv::Mat H;
	std::vector<unsigned char> mask;
	H = cv::findHomography(dst_pts, src_pts, cv::RANSAC, 3.0, mask); // 调整RANSAC精度阈值
	if (H.empty()) {
		return cv::Mat();
	}

	/*****
	 # 检查变换矩阵的合理性
	 angle = np.arctan2(H[1,0], H[0,0]) * 180 / np.pi
	 scale = np.sqrt(H[0,0]**2 + H[1,0]**2)
	 *****/
	double angle = std::atan2(H.at<double>(1, 0), H.at<double>(0, 0))
			* 180.0/ CV_PI;
	double scale = std::sqrt(
			H.at<double>(0, 0) * H.at<double>(0, 0)
					+ H.at<double>(1, 0) * H.at<double>(1, 0));

	/***# 检查平移量
	 translation_x = abs(H[0,2])
	 translation_y = abs(H[1,2])
	 max_translation = max(base_gray.shape) * 0.2  # 允许最大20%的平移
	 ****/
	double translation_x = std::abs(H.at<double>(0, 2));
	double translation_y = std::abs(H.at<double>(1, 2));
	double max_translation = std::max(base_gray.rows, base_gray.cols) * 0.2; // 允许最大20%的平移

	/****# 更严格的变换矩阵验证
	 if (abs(angle) > 20 or  # 降低允许的最大角度
	 scale < 0.8 or scale > 1.2 or  # 收紧缩放范围
	 translation_x > max_translation or
	 translation_y > max_translation):  # 限制平移量
	 return None
	 ****/
	if (std::abs(angle) > 20
			||  // 降低允许的最大角度
			scale < 0.8 || scale > 1.2
			||  // 收紧缩放范围
			translation_x > max_translation
			|| translation_y > max_translation) {  // 限制平移量
		return cv::Mat();
	}

	/***# 应用透视变换
	 h, w = base_gray.shape
	 aligned_img = cv2.warpPerspective(target_img, H, (w, h),
	 flags=cv2.INTER_LINEAR,
	 borderMode=cv2.BORDER_CONSTANT,
	 borderValue=(0,0,0))

	 # cv2.imshow("aligned", aligned_img)
	 ******/
	cv::Mat aligned_img;
	cv::warpPerspective(target_img, aligned_img, H,
			cv::Size(base_gray.cols, base_gray.rows), cv::INTER_LINEAR,
			cv::BORDER_CONSTANT, cv::Scalar(0, 0, 0));

	// cv::imshow("aligned", aligned_img);
	// cv::waitKey(0);
	return aligned_img;
}


//合并坐标
cv::Rect merge_rectangles(const std::vector<cv::Rect> &rectangles,
		int threshold = 50) {
	if (rectangles.empty()) {
		return cv::Rect();
	}

	// 将矩形列表转换为集合，用于跟踪已合并的矩形
	std::set<int> unmerged;
	for (size_t i = 0; i < rectangles.size(); ++i) {
		unmerged.insert(i);
	}

	std::vector<std::set<int>> merged_groups;

	while (!unmerged.empty()) {
		// 从未合并的矩形中取出一个作为新组的起点
		int current = *unmerged.begin();
		unmerged.erase(unmerged.begin());
		std::set<int> current_group = { current };
		bool changed = true;

		// 持续扩展当前组，直到无法找到更多相近的矩形
		while (changed) {
			changed = false;
			std::vector<int> to_remove;
			for (int i : unmerged) {
				for (int j : current_group) {
					const cv::Rect &rect1 = rectangles[i];
					const cv::Rect &rect2 = rectangles[j];

					// 计算两个矩形之间的最小距离
					int r1_left = rect1.x;
					int r1_right = rect1.x + rect1.width;
					int r1_top = rect1.y;
					int r1_bottom = rect1.y + rect1.height;

					int r2_left = rect2.x;
					int r2_right = rect2.x + rect2.width;
					int r2_top = rect2.y;
					int r2_bottom = rect2.y + rect2.height;

					// 计算水平和垂直方向的距离
					int h_dist = std::max(0,
							std::max(r1_left, r2_left)
									- std::min(r1_right, r2_right));
					int v_dist = std::max(0,
							std::max(r1_top, r2_top)
									- std::min(r1_bottom, r2_bottom));

					// 如果矩形在某个方向上重叠，该方向的距离为0
					if (r1_left <= r2_right && r2_left <= r1_right) {
						h_dist = 0;
					}
					if (r1_top <= r2_bottom && r2_top <= r1_bottom) {
						v_dist = 0;
					}

					// 计算最小距离
					double min_distance = std::sqrt(
							h_dist * h_dist + v_dist * v_dist);
					//std::cout << "min_distance: " << min_distance << std::endl;

					if (min_distance <= threshold) {
						current_group.insert(i);
						to_remove.push_back(i);
						changed = true;
						break;
					}
				}
			}
			for (int i : to_remove) {
				unmerged.erase(i);
			}
		}

		// 将当前组添加到已合并组列表中
		merged_groups.push_back(current_group);
	}

	// 对每个合并组计算外接矩形
	std::vector<cv::Rect> merged_rectangles;
	for (const auto &group : merged_groups) {
		int min_x = INT_MAX, min_y = INT_MAX, max_x = 0, max_y = 0;
		for (int i : group) {
			const cv::Rect &rect = rectangles[i];
			min_x = std::min(min_x, rect.x);
			min_y = std::min(min_y, rect.y);
			max_x = std::max(max_x, rect.x + rect.width);
			max_y = std::max(max_y, rect.y + rect.height);
		}
		merged_rectangles.push_back(
				cv::Rect(min_x, min_y, max_x - min_x, max_y - min_y));
	}

	// 如果没有合并后的矩形，返回空矩形
	if (merged_rectangles.empty()) {
		return cv::Rect();
	}

	// 返回面积最大的矩形区域
	auto max_area_rect = *std::max_element(merged_rectangles.begin(),
			merged_rectangles.end(), [](const cv::Rect &a, const cv::Rect &b) {
				return a.width * a.height < b.width * b.height;
			});
	return max_area_rect;
}

// 创建掩码，将图像边界的5%设置成黑色
static void set_border_to_black(cv::Mat &image, int border_h, int border_w) {
	int h = image.rows;
	int w = image.cols;

	// 将顶部和底部边界设置为黑色
	image(cv::Range(0, border_h), cv::Range::all()) = 0;
	image(cv::Range(h - border_h, h), cv::Range::all()) = 0;

	// 将左侧和右侧边界设置为黑色
	image(cv::Range::all(), cv::Range(0, border_w)) = 0;
	image(cv::Range::all(), cv::Range(w - border_w, w)) = 0;
}

std::vector<cv::Rect> find_differences(cv::Mat &base_gray,
		cv::Mat &aligned_gray) {
	/******
	 # 计算边界区域（10%）
	 h, w = base_gray.shape
	 border_h = int(h * 0.05)
	 border_w = int(w * 0.05)

	 # 创建掩码，排除边界区域
	 mask = np.zeros_like(base_gray)
	 mask[border_h:h-border_h, border_w:w-border_w] = 255

	 # 图像预处理 - 减小高斯模糊核大小和标准差
	 base_gray = cv2.GaussianBlur(base_gray, (5, 5), 1.5)
	 aligned_gray = cv2.GaussianBlur(aligned_gray, (5, 5), 1.5)

	 # 计算绝对差异并应用掩码
	 diff = cv2.absdiff(base_gray, aligned_gray)
	 diff = cv2.bitwise_and(diff, diff, mask=mask)

	 # 对差异图像进行阈值处理
	 _, thresh = cv2.threshold(diff, 30, 255, cv2.THRESH_BINARY)

	 # 使用形态学操作去除噪点
	 kernel = np.ones((7,7), np.uint8)
	 thresh = cv2.morphologyEx(thresh, cv2.MORPH_OPEN, kernel)
	 thresh = cv2.morphologyEx(thresh, cv2.MORPH_CLOSE, kernel)

	 # 查找轮廓
	 contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

	 # 设置最小区域尺寸限制为50x50像素
	 min_dimension = 10
	 min_area = min_dimension * min_dimension
	 img_area = base_gray.shape[0] * base_gray.shape[1]
	 max_area = img_area * 0.8   # 保持最大面积限制为50%
	 # 过滤并按面积排序轮廓，同时检查矩形尺寸
	 filtered_contours = []
	 for cnt in contours:
	 area = cv2.contourArea(cnt)
	 if min_area < area < max_area:
	 x, y, w, h = cv2.boundingRect(cnt)
	 if w >= min_dimension and h >= min_dimension:
	 filtered_contours.append(cnt)
	 if not filtered_contours:
	 return ()

	 # 按面积降序排序
	 filtered_contours = sorted(filtered_contours, key=cv2.contourArea, reverse=True)

	 # 保留所有符合条件的差异区域
	 significant_contours = filtered_contours

	 # 获取矩形区域
	 rects = [cv2.boundingRect(cnt) for cnt in significant_contours]
	 **/
	std::vector<cv::Rect> result;

	// 计算边界区域（?%）
	int h = base_gray.rows;
	int w = base_gray.cols;
	int border_h = static_cast<int>(h * 0.05);
	int border_w = static_cast<int>(w * 0.05);
#if 0
    // 创建掩码，排除边界区域
    cv::Mat mask = cv::Mat::zeros(base_gray.size(), CV_8UC1);
    mask(cv::Range(border_h, h - border_h), cv::Range(border_w, w - border_w)).setTo(255);

    // 图像预处理 - 减小高斯模糊核大小和标准差
    cv::Mat blurred_base_gray, blurred_aligned_gray;
    cv::GaussianBlur(base_gray, blurred_base_gray, cv::Size(5, 5), 1.5);
    cv::GaussianBlur(aligned_gray, blurred_aligned_gray, cv::Size(5, 5), 1.5);

    // 计算绝对差异并应用掩码
    cv::Mat diff;
    cv::absdiff(blurred_base_gray, blurred_aligned_gray, diff);
    cv::bitwise_and(diff, diff, mask, diff);
#else
	// 将图像边界的5%设置成黑色
	set_border_to_black(base_gray, border_h, border_w);
	set_border_to_black(aligned_gray, border_h, border_w);

	// 图像预处理 - 减小高斯模糊核大小和标准差
	cv::Size sz(5, 5); //核大小
	double sigmaX = 3.0; //标准差
	cv::Mat blurred_base_gray, blurred_aligned_gray;
	cv::GaussianBlur(base_gray, blurred_base_gray, sz, sigmaX);
	cv::GaussianBlur(aligned_gray, blurred_aligned_gray, sz, sigmaX);

	// 计算绝对差异
	cv::Mat diff;
	cv::absdiff(blurred_base_gray, blurred_aligned_gray, diff);

#if CONFIG_DEBUG_SHOW
    cv::imshow("diff", diff);
#endif

#endif

	// 对差异图像进行阈值处理
	cv::Mat thresh;
	cv::threshold(diff, thresh, 30, 255, cv::THRESH_BINARY);

#if CONFIG_DEBUG_SHOW
    cv::imshow("threshold", thresh);
#endif

	// 使用形态学操作去除噪点
	cv::Mat kernel = cv::getStructuringElement(cv::MORPH_RECT, cv::Size(7, 7));
	cv::morphologyEx(thresh, thresh, cv::MORPH_OPEN, kernel);
	cv::morphologyEx(thresh, thresh, cv::MORPH_CLOSE, kernel);

	// 查找轮廓
	std::vector<std::vector<cv::Point>> contours;
	std::vector<cv::Vec4i> hierarchy;
	cv::findContours(thresh, contours, hierarchy, cv::RETR_EXTERNAL,
			cv::CHAIN_APPROX_SIMPLE);

	// 设置最小区域尺寸限制为50x50像素
	double min_dimension = 10;
	double min_area = min_dimension * min_dimension;
	double img_area = base_gray.rows * base_gray.cols;
	double max_area = img_area * 0.8;   // 保持最大面积限制为80%

	// 过滤并按面积排序轮廓，同时检查矩形尺寸
#if CONFIG_DEBUG_SHOW
    printf("area min:%.2f, max:%.2f\n", min_area, max_area);
#endif

	std::vector<std::vector<cv::Point>> filtered_contours;
	for (const auto &cnt : contours) {
		cv::Rect rect = cv::boundingRect(cnt);
		//double area = rect.width * rect.height;//cv::contourArea(cnt);
		double area = cv::contourArea(cnt);

#if CONFIG_DEBUG_SHOW
        printf("min:%.2f max:%.2f area: %.2f (%d,%d,%d,%d)\n", min_area, max_area, area, rect.x, rect.y, rect.width, rect.height);
#endif

		if (area > min_area && area < max_area) {
			if (rect.width >= min_dimension && rect.height >= min_dimension) {
				filtered_contours.push_back(cnt);
			}
		}
	}

	if (filtered_contours.empty()) {
		//没有
		return result;
	}

	// 按面积降序排序
	std::sort(filtered_contours.begin(), filtered_contours.end(),
			[](const std::vector<cv::Point> &a,
					const std::vector<cv::Point> &b) {
				return cv::contourArea(a) > cv::contourArea(b);
			});

	// 保留所有符合条件的差异区域
	std::vector<cv::Rect> significant_contours;
	for (const auto &cnt : filtered_contours) {
		significant_contours.push_back(cv::boundingRect(cnt));
	}

#if CONFIG_DEBUG_SHOW
    //result = significant_contours;
#endif

	// 合并矩形
	cv::Rect merged_rect = merge_rectangles(significant_contours, 50);
	result.push_back(merged_rect);
	return result;
}

static int compare_image(cv::Mat &img1, cv::Mat &img2, float threshold,
		float *simm, cv::Rect &resbox) {
	if (img1.empty() || img2.empty()) {
		printf("error: not open image\n");
		return -1;
	}

	cv::Mat imgbgr1, imgbgr2;
	cv::cvtColor(img1, imgbgr1, cv::COLOR_RGB2BGR);
	cv::cvtColor(img2, imgbgr2, cv::COLOR_RGB2BGR);

	if (imgbgr1.empty() || imgbgr2.empty()) {
		printf("error: image not to BGR format\n");
		return -1;
	}

	//计算结构相似性指数
	double score = calculate_hist_similarity(imgbgr1, imgbgr2);

	*simm = score;

	//相似的图像,进行对其后寻找差异点
	if (score < threshold) {
		cv::Mat gray1, gray2;

		cv::cvtColor(imgbgr1, gray1, cv::COLOR_BGR2GRAY);
		cv::cvtColor(imgbgr2, gray2, cv::COLOR_BGR2GRAY);

		if (gray1.empty() || gray2.empty()) {
			printf("error: image not to BGR2GRAY format\n");
			return -1;
		}

		//# 对齐图片
		cv::Mat aligned_img = align_images(gray1, gray2, imgbgr2);
		if (aligned_img.empty()) {
			// printf("空对其\n");
			aligned_img = imgbgr2;
		}

#if CONFIG_DEBUG_OUT_IMG
		cv::imwrite("debug_aligned.jpg", aligned_img);
#endif

		cv::Mat aligned_gray;
		cv::cvtColor(aligned_img, aligned_gray, cv::COLOR_BGR2GRAY);

#if CONFIG_DEBUG_SHOW
        cv::imshow("src1", gray1);
        cv::imshow("src2", aligned_gray);

        cv::Mat showMat = gray1.clone();
#endif

		//# 计算差异并标记
		std::vector<cv::Rect> diffs = find_differences(gray1, aligned_gray);

		if (diffs.size()) {
			// 显示结果
#if CONFIG_DEBUG_SHOW

             // 绘制轮廓
            for (const auto& rect : diffs)
                cv::rectangle(showMat, rect, cv::Scalar(233, 245, 0), 2);

            cv::imshow("result", showMat);
            cv::waitKey(0);
#endif
			resbox = diffs[0];
		}
	}
	return 0;
}

cv::Mat resizeAndPad(const cv::Mat &input, int target_size) {
	// 获取原始图像的宽度和高度
	int original_width = input.cols;
	int original_height = input.rows;

	// 如果宽或高超过 target_size，则按比例缩小
	if (original_width > target_size || original_height > target_size) {
		// 计算缩放比例
		float scale = static_cast<float>(target_size)
				/ std::max(original_width, original_height);

		// 计算缩放后的宽度和高度
		int new_width = static_cast<int>(original_width * scale);
		int new_height = static_cast<int>(original_height * scale);

		// 缩放图像
		cv::Mat resized_image;
		cv::resize(input, resized_image, cv::Size(new_width, new_height));

		// 计算填充的大小
		int top_border = (target_size - new_height) / 2;
		int bottom_border = target_size - new_height - top_border;
		int left_border = (target_size - new_width) / 2;
		int right_border = target_size - new_width - left_border;

		// 填充图像
		cv::Mat padded_image;
		cv::copyMakeBorder(resized_image, padded_image, top_border, bottom_border,
				left_border, right_border, cv::BORDER_CONSTANT,
				cv::Scalar(255, 255, 255)); // 使用?色填充

		return padded_image;
	}
	// 如果宽和高都小于 target_size，则填充到 target_size × target_size
	int top_border = (target_size - original_height) / 2;
	int bottom_border = target_size - original_height - top_border;
	int left_border = (target_size - original_width) / 2;
	int right_border = target_size - original_width - left_border;

	printf("直接填充:(%d,%d,%d,%d)\n", top_border, bottom_border, left_border, right_border);

	// 使用 cv::copyMakeBorder 填充图像
	cv::Mat padded_image;
	cv::copyMakeBorder(input, padded_image, top_border, bottom_border, left_border, right_border,
					   cv::BORDER_CONSTANT, cv::Scalar(255, 255, 255)); // 使用?色填充
	return padded_image;
	//return input;
}

extern "C" {


LXAPI void yolo2rect(float yolo_x, float yolo_y, float yolo_w, float yolo_h,
		int imagew, int imageh, int &x, int &y, int &w, int &h) 
{
	// 将 YOLO 格式的归一化坐标转换为像素坐标
	float center_x = yolo_x * imagew;
	float center_y = yolo_y * imageh;
	float box_w = yolo_w * imagew;
	float box_h = yolo_h * imageh;

	// 计算左上角坐标
	x = static_cast<int>(center_x - box_w / 2);
	y = static_cast<int>(center_y - box_h / 2);

	// 宽度和高度
	w = static_cast<int>(box_w);
	h = static_cast<int>(box_h);
}

}

//截图对其
int lxImageCmp3(const char *img_path1, const char *img_path2, 
	float yolo_x, float yolo_y, float yolo_w, float yolo_h, 
	float threshold,
	float *simres, Box *box, const char *cropPath, int resize)
{
	box->x = 0;
	box->y = 0;
	box->w = 0;
	box->h = 0;

	cv::Mat img1 = cv::imread(img_path1); //BGR
	cv::Mat img2 = cv::imread(img_path2); //BGR

	if (img1.empty() || img2.empty()) {
		printf("error: not open image\n");
		return -1;
	}

	if (img1.rows != img2.rows || img1.cols != img2.cols) {
		printf("image size not equ\n");
		return -1;
	}

	int img_width = img1.cols;
	int img_height = img1.rows;
	int x1, y1, box_width, box_height;

	yolo2rect(yolo_x, yolo_y, yolo_w, yolo_h, img_width, img_height, x1, y1,
			box_width, box_height);

	printf("yolo2rect: %d,%d,%d,%d\n", x1, y1, box_width, box_height);
	// 截图
	cv::Mat cropImg1 = img1(cv::Rect(x1, y1, box_width, box_height)).clone();
	cv::Mat cropImg2 = img2(cv::Rect(x1, y1, box_width, box_height)).clone();

	//计算结构相似性指数
	double score = calculate_hist_similarity(cropImg1, cropImg2);
	*simres=score;
	if (score > threshold) {
		return 0;
	}

	if (cropPath && strlen(cropPath) > 0) {
		if (resize > 0) {
			cv::Mat out = resizeAndPad(cropImg1, resize);
			cv::imwrite(cropPath, out);
		} else
			cv::imwrite(cropPath, cropImg1);
	}

	cv::Mat imgbgr1, imgbgr2;
	cv::cvtColor(cropImg1, imgbgr1, cv::COLOR_RGB2BGR); //默认imread就是BGR
	cv::cvtColor(cropImg2, imgbgr2, cv::COLOR_RGB2BGR);

	cv::Mat gray1, gray2;
	cv::cvtColor(imgbgr1, gray1, cv::COLOR_BGR2GRAY);
	cv::cvtColor(imgbgr2, gray2, cv::COLOR_BGR2GRAY);

	//# 对齐图片
	cv::Mat aligned_img = align_images(gray1, gray2, imgbgr2);
	if (aligned_img.empty()) {
		printf("空对其\n");
		aligned_img = imgbgr2;
	}

	cv::Mat crop_gray2;
	cv::cvtColor(aligned_img, crop_gray2, cv::COLOR_BGR2GRAY);

	printf("diff:(%d,%d) (%d,%d)\n", gray1.cols, gray1.rows, crop_gray2.cols, crop_gray2.rows);
	//# 计算差异并标记
	std::vector<cv::Rect> diffs = find_differences(gray1, crop_gray2);
	if (diffs.size()) {
		box->x = diffs[0].x + x1;
		box->y = diffs[0].y + y1;
		box->w = diffs[0].width;
		box->h = diffs[0].height;
		
		float rect_area = box->w * box->h;
		float box_area = box_width * box_height;
		if (rect_area / box_area >0.8) {
			box->x = 0;
			box->y = 0;
			box->w = 0;
			box->h = 0;
		}
	}
	return 0;
}

//大图对其
//img1 样本图像
//img2 实时图像
//yolo: yolo标签
//threshold: 对比阈值
//simres: 切图的直方对比阈值
//box: 大图中的坐标
//cropPath 实时图像切图路径 长度 >0 时 保存: /tmp/aaaa.jpg
//resize: 缩放:640,0不缩放
int lxImageCmp2(const char *img_path1, const char *img_path2, float yolo_x,
		float yolo_y, float yolo_w, float yolo_h, float threshold,
		float *simres, Box *box, const char *cropPath, int resize) {
	box->x = 0;
	box->y = 0;
	box->w = 0;
	box->h = 0;

	cv::Mat img1 = cv::imread(img_path1); //RGB
	cv::Mat img2 = cv::imread(img_path2); //RGB

	if (img1.empty() || img2.empty()) {
		printf("error: not open image\n");
		return -1;
	}

	if (img1.rows != img2.rows || img1.cols != img2.cols) {
		printf("image size not equ\n");
		return -1;
	}

	cv::Mat imgbgr1, imgbgr2; //BGR
	cv::cvtColor(img1, imgbgr1, cv::COLOR_RGB2BGR);
	cv::cvtColor(img2, imgbgr2, cv::COLOR_RGB2BGR);

	if (imgbgr1.empty() || imgbgr2.empty()) {
		printf("error: image not to BGR format\n");
		return -1;
	}

	int img_width = img1.cols;
	int img_height = img1.rows;
	int x1, y1, box_width, box_height;

	yolo2rect(yolo_x, yolo_y, yolo_w, yolo_h, img_width, img_height, x1, y1,
			box_width, box_height);

	cv::Mat gray1, gray2;

	cv::cvtColor(imgbgr1, gray1, cv::COLOR_BGR2GRAY);
	cv::cvtColor(imgbgr2, gray2, cv::COLOR_BGR2GRAY);

	//# 对齐图片
	cv::Mat aligned_img = align_images(gray1, gray2, imgbgr2);
	if (aligned_img.empty()) {
		printf("空对其\n");
		aligned_img = imgbgr2;
	}

	// 截图
	cv::Mat cropImg1 = imgbgr1(cv::Rect(x1, y1, box_width, box_height)).clone();
	cv::Mat cropImg2 = aligned_img(cv::Rect(x1, y1, box_width, box_height)).clone();

	//计算结构相似性指数
	double score = calculate_hist_similarity(cropImg1, cropImg2);
	printf("score=%.2f\n", score);
	*simres = score;

	//相似的图像,进行对其后寻找差异点
	if (score > threshold) {
		return 0;
	}
	if (cropPath && strlen(cropPath) > 0) {
		if (resize > 0) {
			cv::Mat out = resizeAndPad(cropImg2, resize);
			cv::imwrite(cropPath, out);
		} else
			cv::imwrite(cropPath, cropImg2);
	}
	cv::Mat crop_gray1, crop_gray2;

	cv::cvtColor(cropImg1, crop_gray1, cv::COLOR_BGR2GRAY);
	cv::cvtColor(cropImg2, crop_gray2, cv::COLOR_BGR2GRAY);

#if CONFIG_DEBUG_SHOW
	cv::imshow("c1", crop_gray1);
	cv::imshow("c2", crop_gray2);
#endif

	//# 计算差异并标记
	std::vector<cv::Rect> diffs = find_differences(crop_gray1, crop_gray2);
	if (diffs.size()) {

		// 显示结果
#if CONFIG_DEBUG_SHOW
		cv::Mat showMat = cropImg1.clone();

		// 绘制轮廓
		std::cout << "==========================" << std::endl;
		for (const auto& rect : diffs) {
		    std::cout << rect.x << "," << rect.y << "," << rect.width << "," << rect.height << std::endl;
		    cv::rectangle(showMat, rect, cv::Scalar(233, 245, 0), 2);
		}

		cv::imshow("result", showMat);
#endif

		box->x = diffs[0].x + x1;
		box->y = diffs[0].y + y1;
		box->w = diffs[0].width;
		box->h = diffs[0].height;
	} else {
		printf("not find. 无差异点坐标\n");
	}

#if CONFIG_DEBUG_SHOW
	    cv::waitKey(0);
#endif
	return 0;
}

//@simres: 0~1
//return 0:success !0: error
int lxImageCmp(const char* path1, const char* path2, float threshold,
	float* simres, Box* box) {
	cv::Rect rect(0, 0, 0, 0);
	cv::Mat mat1 = cv::imread(path1);
	cv::Mat mat2 = cv::imread(path2);

	int ret = 0;

	if (mat1.empty() || mat2.empty()) {
		std::cout << "Failed to open one or both images: " << path1 << ", "
			<< path2 << std::endl;
		return -1;
	}
	if (mat1.size() != mat2.size()) {
		std::cout << "Images have different sizes." << std::endl;
		std::cout << "Size of image1: " << mat1.size() << std::endl;
		std::cout << "Size of image2: " << mat2.size() << std::endl;
		return -2;
	}

	try {
		ret = compare_image(mat1, mat2, threshold, simres, rect);
		if (ret != 0)
			return -1;
		box->x = rect.x;
		box->y = rect.y;
		box->w = rect.width;
		box->h = rect.height;
		return 0;
	}
	catch (...) {
		std::cout << "exception" << std::endl;
	}
	return -1;
}

