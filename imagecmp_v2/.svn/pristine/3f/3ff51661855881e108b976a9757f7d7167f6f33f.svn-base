#if 0

#include <algorithm>
#include <fstream>
#include <iostream>
#include <mutex>
#include <sstream>
#include <string>
#include <vector>

#include <opencv2/opencv.hpp>
#include <onnxruntime_cxx_api.h>

struct MatchResult {
	std::vector<cv::Point2f> keypoints_left;
	std::vector<cv::Point2f> keypoints_right;
	std::vector<cv::Point2f> matched_left;
	std::vector<cv::Point2f> matched_right;
};

class ImageMatcher {
private:
	std::string model_path_;
	int height_;
	int width_;

	float DISTANCE_THRESHOLD = 150.0f;
	float CONFIDENCE_THRESHOLD = 0.5f;
	int MAX_KEYPOINTS = 1024;
	int MIN_GLOBAL_MATCHES = 150;
	int MIN_BOX_MATCHES = 5;
	int MAX_BOX_AREA = 2000;

	Ort::Env env_;
	Ort::SessionOptions session_options_;
	std::unique_ptr<Ort::Session> session_;
	std::mutex session_mutex_;

public:
	ImageMatcher(const std::string& model_path = "weights/superpoint_lightglue_pipeline.onnx")
		: env_(ORT_LOGGING_LEVEL_WARNING, "ImageMatcher"),
		model_path_(model_path),
		height_(512),
		width_(512) {

		session_options_.SetGraphOptimizationLevel(GraphOptimizationLevel::ORT_DISABLE_ALL);
		session_options_.SetExecutionMode(ExecutionMode::ORT_PARALLEL);
		session_options_.SetIntraOpNumThreads(2);
		session_options_.SetInterOpNumThreads(2);

#ifdef  _WIN32
		std::wstring wide_model_path(model_path.begin(), model_path.end());
		this->session_ = std::make_unique<Ort::Session>(env_, wide_model_path.c_str(), session_options_);
#else
		this->session_ = std::make_unique<Ort::Session>(env_, model_path.c_str(), session_options_);
#endif
	}

	std::vector<cv::Mat> preprocess_images(const std::vector<cv::Mat>& images) {
		std::vector<cv::Mat> processed;

		for (const auto& img : images) {
			cv::Mat gray;
			if (img.channels() == 3) {
				cv::cvtColor(img, gray, cv::COLOR_BGR2GRAY);
			} else {
				gray = img.clone();
			}

			cv::Mat normalized;
			gray.convertTo(normalized, CV_32F, 1.0 / 255.0);
			processed.push_back(normalized);
		}

		return processed;
	}

	std::vector<std::vector<float>> parse_yolo_file(const std::string& filepath) {
		std::vector<std::vector<float>> boxes;

		std::ifstream file(filepath);
		if (!file.is_open()) {
			return boxes;
		}

		std::string line;
		while (std::getline(file, line)) {
			std::istringstream iss(line);
			std::vector<float> values;
			float val;

			while (iss >> val) {
				values.push_back(val);
			}

			if (values.size() != 5) continue;

			int class_id = static_cast<int>(values[0]);
			float center_x = values[1] * width_;
			float center_y = values[2] * height_;
			float width = values[3] * width_;
			float height = values[4] * height_;

			float half_width = width / 2.0f;
			float half_height = height / 2.0f;

			int x_min = std::max(0, static_cast<int>(center_x - half_width));
			int y_min = std::max(0, static_cast<int>(center_y - half_height));
			int x_max = std::min(width_ - 1, static_cast<int>(center_x + half_width));
			int y_max = std::min(height_ - 1, static_cast<int>(center_y + half_height));

			boxes.push_back({
				static_cast<float>(class_id),
				static_cast<float>(x_min),
				static_cast<float>(y_min),
				static_cast<float>(x_max),
				static_cast<float>(y_max)
				});
		}

		return boxes;
	}

	MatchResult get_matches(const cv::Mat& left_img, const cv::Mat& right_img) {
		cv::Mat left_img_resize;
		cv::Mat right_img_resize;

		cv::resize(left_img, left_img_resize, cv::Size(width_, height_));
		cv::resize(right_img, right_img_resize, cv::Size(width_, height_));

		std::vector<cv::Mat> images = { left_img_resize, right_img_resize };
		auto preprocessed = preprocess_images(images);

		std::vector<int64_t> input_shape = { 2, 1, height_, width_ };
		size_t input_size = (size_t)2 * 1 * height_ * width_;

		std::vector<float> input_values;
		for (const auto& img : preprocessed) {
			input_values.insert(input_values.end(), img.ptr<float>(), img.ptr<float>() + img.total());
		}

		Ort::MemoryInfo memory_info = Ort::MemoryInfo::CreateCpu(
			OrtAllocatorType::OrtArenaAllocator, OrtMemType::OrtMemTypeDefault);

		Ort::Value input_tensor = Ort::Value::CreateTensor<float>(
			memory_info, input_values.data(), input_size, input_shape.data(), input_shape.size());

		std::vector<char*> inp_names = { (char*)"images" };
		std::vector<char*> out_names = { (char*)"keypoints", (char*)"matches", (char*)"mscores" };

		std::lock_guard<std::mutex> lock(session_mutex_);
		auto output_tensors = session_->Run(
			Ort::RunOptions{ nullptr },
			inp_names.data(),
			&input_tensor,
			1,
			out_names.data(),
			out_names.size()
		);

		int64_t* keypoints_data = output_tensors[0].GetTensorMutableData<int64_t>();
		int64_t* matches_data = output_tensors[1].GetTensorMutableData<int64_t>();
		float* match_scores_data = output_tensors[2].GetTensorMutableData<float>();

		auto keypoints_shape = output_tensors[0].GetTensorTypeAndShapeInfo().GetShape();
		auto matches_shape = output_tensors[1].GetTensorTypeAndShapeInfo().GetShape();

		std::vector<cv::Point2f> kp_left, kp_right;
		size_t left_kp_count = (size_t)keypoints_shape[1];

		for (size_t i = 0; i < left_kp_count; ++i) {
			if ((int)i >= MAX_KEYPOINTS) break;
			kp_left.emplace_back(
				(float)keypoints_data[i * 2],
				(float)keypoints_data[i * 2 + 1]);
		}

		for (size_t i = 0; i < left_kp_count; ++i) {
			if ((int)i >= MAX_KEYPOINTS) break;
			kp_right.emplace_back(
				(float)keypoints_data[left_kp_count * 2 + i * 2],
				(float)keypoints_data[left_kp_count * 2 + i * 2 + 1]);
		}

		std::vector<cv::Point2f> matched_left;
		std::vector<cv::Point2f> matched_right;

		for (size_t i = 0; i < (size_t)matches_shape[0]; ++i) {
			if (match_scores_data[i] <= CONFIDENCE_THRESHOLD) continue;
			if (matches_data[i * 3] != 0) continue;

			int64_t left_idx = matches_data[i * 3 + 1];
			int64_t right_idx = matches_data[i * 3 + 2];

			if (left_idx < 0 || right_idx < 0) continue;
			if ((size_t)left_idx >= kp_left.size() || (size_t)right_idx >= kp_right.size()) continue;

			cv::Point2f pt_left = kp_left[(size_t)left_idx];
			cv::Point2f pt_right = kp_right[(size_t)right_idx];

			float distance = cv::norm(pt_left - pt_right);
			if (distance <= DISTANCE_THRESHOLD) {
				matched_left.push_back(pt_left);
				matched_right.push_back(pt_right);
			}
		}

		return { kp_left, kp_right, matched_left, matched_right };
	}

	cv::Rect resizePoint(const cv::Rect& srcRect, int srcW, int srcH, int dstW, int dstH) {
		float scaleX = static_cast<float>(dstW) / srcW;
		float scaleY = static_cast<float>(dstH) / srcH;

		int x = static_cast<int>(srcRect.x * scaleX);
		int y = static_cast<int>(srcRect.y * scaleY);
		int w = static_cast<int>(srcRect.width * scaleX);
		int h = static_cast<int>(srcRect.height * scaleY);

		x = std::max(0, x);
		y = std::max(0, y);
		w = std::max(0, w);
		h = std::max(0, h);

		x = std::min(x, dstW - 1);
		y = std::min(y, dstH - 1);
		w = std::min(w, dstW - x);
		h = std::min(h, dstH - y);

		return cv::Rect(x, y, w, h);
	}

	bool feature_match(int x_min, int y_min, int x_max, int y_max, std::vector<cv::Point2f>& matched_kp_l,
		std::vector<cv::Point2f>& match_l, std::vector<cv::Point2f>& match_r, cv::Rect& tarrec)
	{
		std::cout << "全部特征点总数:" << matched_kp_l.size() << " 匹配特征点:" << match_l.size() << std::endl;

		if ((int)match_l.size() <= MIN_GLOBAL_MATCHES) {
			return false;
		}

		int w = x_max - x_min;
		int h = y_max - y_min;
		int box_area = w * h;

		if (box_area <= MAX_BOX_AREA) {
			printf("特征匹配(%d,%d,%d,%d):box_area:%d<%d\n", x_min, y_min, x_max, y_max, box_area, MAX_BOX_AREA);
			tarrec = cv::Rect(x_min, y_min, (x_max - x_min), (y_max - y_min));
			return true;
		}

		int matches_in_box = 0;
		for (const auto& pt : matched_kp_l) {
			if (pt.x >= x_min && pt.x <= x_max && pt.y >= y_min && pt.y <= y_max) {
				matches_in_box++;
			}
		}

		printf("匹配到yolo框内坐标点的个数:%d, (%d,%d,%d,%d)\n", matches_in_box, x_min, y_min, x_max, y_max);

		if (matches_in_box >= MIN_BOX_MATCHES) {
			cv::Mat H = cv::Mat();
			if ((int)match_l.size() >= MIN_BOX_MATCHES && (int)match_r.size() >= MIN_BOX_MATCHES) {
				H = cv::findHomography(match_l, match_r, cv::RANSAC, 0.5);
			}
			std::vector<cv::Point2f> pts = {
				cv::Point2f((float)x_min, (float)y_min),
				cv::Point2f((float)x_max, (float)y_min),
				cv::Point2f((float)x_max, (float)y_max),
				cv::Point2f((float)x_min, (float)y_max)
			};

			std::vector<cv::Point2f> dst_corners;
			cv::perspectiveTransform(pts, dst_corners, H);

			int tarxmin = static_cast<int>(dst_corners[0].x);
			int tarymin = static_cast<int>(dst_corners[0].y);
			int tarxmax = static_cast<int>(dst_corners[2].x);
			int tarymax = static_cast<int>(dst_corners[2].y);

			tarrec = cv::Rect(tarxmin, tarymin, (tarxmax - tarxmin), (tarymax - tarymin));
			return true;
		}

		std::cout << "特征匹配未找到" << std::endl;

		tarrec = cv::Rect(0, 0, 0, 0);
		return false;
	}

	bool feature_match(cv::Rect srcbox, int bW, int bH, std::vector<cv::Point2f>& matched_kp_l,
		std::vector<cv::Point2f>& match_l, std::vector<cv::Point2f>& match_r, cv::Rect& tarrec)
	{
		cv::Rect box = resizePoint(srcbox, bW, bH, width_, height_);

		int x_min = box.x;
		int y_min = box.y;
		int x_max = box.x + box.width;
		int y_max = box.y + box.height;

		return feature_match(x_min, y_min, x_max, y_max, matched_kp_l, match_l, match_r, tarrec);
	}

	cv::Rect outRect(cv::Rect srcRect, int dstW, int dstH) {
		return resizePoint(srcRect, width_, height_, dstW, dstH);
	}
};

#endif

