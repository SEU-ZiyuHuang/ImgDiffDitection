#include <iostream>
#include <vector>
#include <string>
#include <algorithm>

#include "imagecmp.h"

static double multi_region_blur_check(cv::Mat image, const std::pair<int, int>& grid = {3, 3})
{
    int h = image.rows;
    int w = image.cols;
    std::vector<double> variances;
    
    // 遍历网格中的每个区域
    for (int i = 0; i < grid.first; ++i) {
        for (int j = 0; j < grid.second; ++j) {
            // 计算当前区域的坐标
            int y1 = i * h / grid.first;
            int y2 = (i + 1) * h / grid.first;
            int x1 = j * w / grid.second;
            int x2 = (j + 1) * w / grid.second;
            
            // 提取区域ROI
            cv::Mat roi = image(cv::Range(y1, y2), cv::Range(x1, x2));
            
            // 计算拉普拉斯算子并求方差
            cv::Mat laplacian;
            cv::Laplacian(roi, laplacian, CV_64F);
            
            // 计算方差: 所有通道合并计算
            cv::Scalar mean, stddev;
            cv::meanStdDev(laplacian, mean, stddev);
            double variance = std::pow(stddev[0], 2);
            
            variances.push_back(variance);
        }
    }
    
    // 返回最小方差
    return *std::min_element(variances.begin(), variances.end());
}


extern "C" {


    LXAPI int lxLaplacianBak(const char* imagePath, double threshold, int* is_blurred, double* score)
    {
        try {
            // 读取图像
            cv::Mat image = cv::imread(imagePath, cv::IMREAD_COLOR);
            if (image.empty()) {
                std::cerr << "Error: Could not read image: " << imagePath << std::endl;
                return 0;
            }

            double blur_score = multi_region_blur_check(image);

            if (score)
                *score = blur_score;

            *is_blurred = blur_score > threshold;
        }
        catch (const std::exception& e) {
            std::cerr << "错误: " << e.what() << std::endl;
            return 0;
        }
        return 1;
    }

}
